    "# Agrupamos ventas globales por año y los ordenamos\n",
    "ventas_año = df.groupby('Year')['Global_Sales'].sum().sort_index()\n",
    "\n",
    "# Creamos la figura\n",
    "plt.figure(figsize=(12, 6))\n",
    "\n",
    "# Línea en lugar de barras, mejor para mostrar evolución en el tiempo\n",
    "plt.plot(ventas_año.index, ventas_año.values, color='teal', linewidth=2, marker='o', markersize=4)\n",
    "\n",
    "# Etiquetas y título\n",
    "plt.xlabel('Año')\n",
    "plt.ylabel('Ventas Globales (millones)')\n",
    "plt.title('Evolución de Ventas de Videojuegos por Año')\n",
    "\n",
    "# Rotamos años para que no se encimen\n",
    "plt.xticks(rotation=45)\n",
    "\n",
