   "source": [
    "# Sumamos ventas totales por región\n",
    "regiones = {\n",
    "    'Norteamérica': df['NA_Sales'].sum(),\n",
    "    'Europa': df['EU_Sales'].sum(),\n",
    "    'Japón': df['JP_Sales'].sum(),\n",
    "    'Otros': df['Other_Sales'].sum()\n",
    "}\n",
    "\n",
    "# Convertimos el diccionario a Series de pandas\n",
    "regiones_series = pd.Series(regiones)\n",
    "\n",
    "# Creamos la figura\n",
    "plt.figure(figsize=(8, 8))\n",
    "\n",
    "# Gráfica de pay (pie chart)\n",
    "plt.pie(regiones_series.values, labels=regiones_series.index, autopct='%1.1f%%', colors=['steelblue', 'coral', 'mediumpurple', 'teal'])\n",
    "\n",
    "plt.title('Distribución de Ventas por Región')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
